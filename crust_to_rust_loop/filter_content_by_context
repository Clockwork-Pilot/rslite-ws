#!/usr/bin/env python3
"""
Filter and emit project files based on context JSON with recursion depth support.

Usage:
  # Option 1: Use custom JSON path (no other env vars needed)
  export CONTEXT_PATH="/path/to/context.json"
  ./filter_content_by_context.py

  # Option 2: Use function name lookup
  export PORTING_FUNCS="main"
  ./filter_content_by_context.py                      # Emit root function's file
  ./filter_content_by_context.py src/deduplicator.rs  # Emit specific file
  ./filter_content_by_context.py --depth 0 src/deduplicator.rs

  # Can be run from any directory that can resolve to context-full/
  cd /path/to/context-full/.. && PORTING_FUNCS=main ./filter_content_by_context.py

Environment variables:
  CONTEXT_PATH - Direct path to context JSON file (optional, omits need for other vars)
  PORTING_FUNCS - The root function name (required if CONTEXT_PATH not set)
  RECURSION_DEPTH - Recursion depth (0=sig only, 1=body+callee sigs, 2=full) [default: 0]
  WORK_DIR - Working directory or project root [default: .]

Command-line arguments:
  [FILE_PATH] - Relative path of file to emit (e.g., src/deduplicator.rs)
                If not specified, emits root function's file
  --depth N   - Override recursion depth (0, 1, or 2)
  --apply-fix "code" - Apply new function implementation to source file

Behavior:
  - Finds context-full/ directory from WORK_DIR or by searching upward
  - Loads the single JSON file matching PORTING_FUNCS
  - Applies recursion depth filtering to root function
  - Emits requested file with appropriate depth level
  - All paths in JSON are relative to project root
  - Module declarations: always shown
  - Use statements: always shown
  - All types: always shown in full
  - Functions in dependency chain: shown according to depth
  - Other functions: shown as signatures only
"""

import json
import sys
import os
from pathlib import Path

try:
    import tree_sitter
    from tree_sitter import Language, Parser
    TREE_SITTER_AVAILABLE = True
except ImportError:
    TREE_SITTER_AVAILABLE = False


def find_context_dir(start_dir=None):
    """Find context-full directory starting from start_dir or searching upward."""
    if start_dir is None:
        start_dir = "."

    current = Path(start_dir).resolve()

    # Check if context-full exists in current directory
    context_full = current / "context-full"
    if context_full.is_dir():
        return str(current)

    # Search upward
    for parent in current.parents:
        context_full = parent / "context-full"
        if context_full.is_dir():
            return str(parent)

    # If not found, try current directory anyway (might be inside context-full)
    return str(current)


def find_json_file(project_root, function_name):
    """Find the JSON file in context-full/ directory matching the function name.

    Filenames follow pattern: path-with-dashes-linenum-functionname.json
    E.g.: src-ctime-rs-2-sqlite3CompileOptions.json
    """
    context_dir = Path(project_root) / "context-full"
    if not context_dir.is_dir():
        print(f"Error: context-full directory not found at {context_dir}", file=sys.stderr)
        sys.exit(1)

    json_files = list(context_dir.glob("*.json"))
    if not json_files:
        print(f"Error: No JSON files found in {context_dir}", file=sys.stderr)
        sys.exit(1)

    # First try: match function name in filename (fast pattern match)
    matches_by_filename = []
    for json_file in json_files:
        filename = json_file.name
        # Filename ends with -functionname.json
        # Extract the part after the last dash and before .json
        name_part = filename.rsplit('-', 1)[-1].replace('.json', '')
        if name_part == function_name:
            matches_by_filename.append(json_file)

    if matches_by_filename:
        if len(matches_by_filename) == 1:
            return str(matches_by_filename[0])
        # If multiple filename matches, parse JSON to disambiguate
        matches = []
        for json_file in matches_by_filename:
            try:
                with open(json_file, 'r') as f:
                    data = json.load(f)
                    full_path = data.get("full_path", "")
                    if full_path == function_name or full_path.endswith("::" + function_name):
                        matches.append(json_file)
            except Exception:
                continue
        if matches:
            return str(matches[0])

    # Fallback: search by parsing JSON (slower, for qualified names like crate::module::func)
    matches = []
    for json_file in json_files:
        try:
            with open(json_file, 'r') as f:
                data = json.load(f)
                full_path = data.get("full_path", "")
                if full_path == function_name or full_path.endswith("::" + function_name):
                    matches.append(json_file)
        except Exception:
            continue

    if not matches:
        print(f"Error: No JSON file found for function '{function_name}' in {context_dir}", file=sys.stderr)
        sys.exit(1)

    if len(matches) > 1:
        print(f"Error: Multiple JSON files found for function '{function_name}':", file=sys.stderr)
        for match in sorted(matches):
            print(f"  - {match.name}", file=sys.stderr)
        print(f"Please specify the full qualified name (e.g., crate::module::function)", file=sys.stderr)
        sys.exit(1)

    return str(matches[0])


def load_context_json(json_path):
    """Load the context JSON file."""
    try:
        with open(json_path, 'r') as f:
            return json.load(f)
    except Exception as e:
        print(f"Error reading {json_path}: {e}", file=sys.stderr)
        sys.exit(1)


def get_dependency_chain(data):
    """Extract full set of functions in the dependency chain from callee_details."""
    chain = set()
    chain.add(data.get("full_path", ""))  # Add root function

    for callee in data.get("callee_details", []):
        chain.add(callee.get("full_path", ""))

    return chain


def apply_recursion_depth(data, depth):
    """Filter data based on recursion depth.

    depth=0: Only root function signature (no body, no callees)
    depth=1+: Full context (root body + callee bodies from callee_details)
    """
    if depth == 0:
        # Strip function body, keep only signature
        data_copy = data.copy()
        data_copy['source'] = ""
        data_copy['callee_details'] = []
        return data_copy
    else:
        # depth=1 or higher: full context (no filtering)
        return data






def apply_fix_to_file(file_path, data, new_function):
    """Apply a new function implementation to the source file.

    Try to replace using line numbers first, fall back to tree-sitter if that fails.
    """
    try:
        # Read the file
        with open(file_path, 'r') as f:
            lines = f.readlines()

        root_full_path = data.get("full_path", "")
        body_lines = data.get("body_lines", [])

        if not body_lines or len(body_lines) < 2:
            print(f"Error: Invalid body_lines in JSON: {body_lines}", file=sys.stderr)
            return False

        line_start = body_lines[0]
        line_end = body_lines[1]

        # Try to replace using line numbers (1-indexed in JSON, 0-indexed for list)
        try:
            # Replace lines from line_start to line_end
            new_lines = lines[:line_start-1] + [new_function + "\n"] + lines[line_end:]

            with open(file_path, 'w') as f:
                f.writelines(new_lines)

            print(f"✓ Applied fix to {file_path} (lines {line_start}-{line_end})", file=sys.stderr)
            return True
        except (IndexError, ValueError):
            # Line numbers drifted, try tree-sitter
            if TREE_SITTER_AVAILABLE:
                print(f"Line numbers drifted, trying tree-sitter...", file=sys.stderr)
                return apply_fix_with_tree_sitter(file_path, root_full_path, new_function)
            else:
                print(f"Error: Line numbers out of bounds and tree-sitter not available", file=sys.stderr)
                print(f"Install tree-sitter: pip install tree-sitter", file=sys.stderr)
                return False

    except Exception as e:
        print(f"Error applying fix: {e}", file=sys.stderr)
        return False


def apply_fix_with_tree_sitter(file_path, function_name, new_function):
    """Use tree-sitter to find and replace a function."""
    if not TREE_SITTER_AVAILABLE:
        print("Error: tree-sitter not installed", file=sys.stderr)
        return False

    try:
        # Read file
        with open(file_path, 'r') as f:
            source = f.read()

        # Parse with tree-sitter
        # Note: This requires tree-sitter-python or appropriate language library
        # For now, we'll do a simpler regex-based replacement as fallback
        import re

        # Extract function name from full_path (e.g., "crate::main" -> "main")
        fn_name = function_name.split("::")[-1]

        # Pattern to match function: "fn name(...) { ... }"
        # This is a simplified pattern that works for most cases
        pattern = rf'(fn\s+{re.escape(fn_name)}\s*\([^)]*\)\s*(?:->\s*[^{{]*)?)\{{[^}}]*\}}'

        # Replace with new function
        modified = re.sub(pattern, new_function, source, flags=re.DOTALL)

        if modified != source:
            with open(file_path, 'w') as f:
                f.write(modified)
            print(f"✓ Applied fix to {file_path} using tree-sitter", file=sys.stderr)
            return True
        else:
            print(f"Error: Could not find function {fn_name} in {file_path}", file=sys.stderr)
            return False

    except Exception as e:
        print(f"Error with tree-sitter replacement: {e}", file=sys.stderr)
        return False


def emit_cargo_toml():
    """Read and emit Cargo.toml to stdout."""
    try:
        with open("Cargo.toml", 'r') as f:
            content = f.read()
        print(f"// Cargo.toml")
        print()
        print(content)
    except FileNotFoundError:
        print("Error: Cargo.toml not found", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Error reading Cargo.toml: {e}", file=sys.stderr)
        sys.exit(1)


def main():
    """Main entry point."""
    # Get working directory from environment
    work_dir = os.environ.get("WORK_DIR", ".")
    if not os.path.isdir(work_dir):
        print(f"Error: WORK_DIR '{work_dir}' is not a valid directory", file=sys.stderr)
        sys.exit(1)

    # Parse command-line arguments
    file_path_arg = None
    depth_arg = None
    apply_fix_code = None

    args = sys.argv[1:]
    i = 0
    while i < len(args):
        arg = args[i]
        if arg == "--depth" and i + 1 < len(args):
            depth_arg = int(args[i + 1])
            i += 2
        elif arg == "--apply-fix" and i + 1 < len(args):
            apply_fix_code = args[i + 1]
            i += 2
        elif not arg.startswith("-"):
            file_path_arg = arg
            i += 1
        else:
            i += 1

    # Load the JSON context file from hardcoded path
    json_file = os.path.join(work_dir, "porting_file.json")
    if not os.path.isfile(json_file):
        print(f"Error: porting_file.json not found at {json_file}", file=sys.stderr)
        sys.exit(1)
    function_name = None

    data = load_context_json(json_file)

    # Get recursion depth: command-line > environment > JSON default
    if depth_arg is not None:
        depth = depth_arg
    else:
        depth = int(os.environ.get("RECURSION_DEPTH", data.get("recursion_depth", 0)))

    data = apply_recursion_depth(data, depth)

    # Get root function's file from JSON
    root_file = data.get("file", "")
    if not root_file:
        print("Error: Could not determine root function file from JSON", file=sys.stderr)
        sys.exit(1)

    # Get project structure and metadata
    project_structure = data.get("project_structure", {})
    if not project_structure:
        print(f"Error: No project_structure in {json_file}", file=sys.stderr)
        sys.exit(1)

    # Determine which file to emit
    if file_path_arg:
        # User specified a file - paths in project_structure are relative
        file_path = file_path_arg

        # Try exact match first
        if file_path not in project_structure:
            # Try matching the basename
            basename = file_path.split("/")[-1]
            matches = []
            for proj_file in project_structure.keys():
                if proj_file.endswith(basename) or proj_file.endswith("/" + basename):
                    matches.append(proj_file)

            if len(matches) == 1:
                file_path = matches[0]
            elif len(matches) > 1:
                print(f"Error: Multiple files match '{file_path_arg}':", file=sys.stderr)
                for match in sorted(matches):
                    print(f"  - {match}", file=sys.stderr)
                print(f"Please specify the full path to disambiguate", file=sys.stderr)
                sys.exit(1)
            elif not matches:
                print(f"Error: File {file_path_arg} not found in project_structure", file=sys.stderr)
                print(f"  Available files: {sorted(project_structure.keys())}", file=sys.stderr)
                sys.exit(1)
    else:
        # Use root function's file - root_file is already relative
        file_path = root_file
        if file_path not in project_structure:
            print(f"Error: Could not find root function file in project_structure", file=sys.stderr)
            print(f"  Root file from JSON: {root_file}", file=sys.stderr)
            print(f"  Available files: {list(project_structure.keys())}", file=sys.stderr)
            sys.exit(1)

    # Get root function information
    root_full_path = data.get("full_path", "")
    root_file = data.get("file", "")
    root_source = data.get("source", "")
    recursion_depth = data.get("recursion_depth", 0)
    callee_details = data.get("callee_details", [])

    # Build set of functions in dependency chain
    dep_chain = set()
    dep_chain.add(root_full_path)
    for callee in callee_details:
        dep_chain.add(callee.get("full_path", ""))

    # Determine if requested file contains root function
    is_root_file = False
    if root_file:
        # Normalize paths for comparison (strip project root if present)
        normalized_root = root_file
        if normalized_root.endswith("/" + file_path) or normalized_root == file_path:
            is_root_file = True

    # Handle --apply-fix mode
    if apply_fix_code:
        # Apply the fix to the actual source file
        if is_root_file:
            # Apply fix to porting_file.rs
            fix_file_path = os.path.join(work_dir, "porting_file.rs")

            success = apply_fix_to_file(fix_file_path, data, apply_fix_code)
            if success:
                func_label = function_name or root_full_path
                print(f"✓ Applied fix to {func_label}", file=sys.stderr)
                return
            else:
                sys.exit(1)
        else:
            print(f"Error: --apply-fix only works with the root function's file", file=sys.stderr)
            print(f"Root function is in: {root_file}", file=sys.stderr)
            sys.exit(1)

    # Get file structure from project_structure
    if file_path not in project_structure:
        print(f"Error: File {file_path} not found in project_structure", file=sys.stderr)
        sys.exit(1)

    file_info = project_structure[file_path]
    if not isinstance(file_info, dict):
        print(f"Error: Invalid file_info for {file_path}", file=sys.stderr)
        sys.exit(1)

    imports = file_info.get("imports", [])
    items = file_info.get("items", [])

    # Emit file path marker
    print(f"// {root_full_path}")
    print()

    # Emit module declarations
    modules = file_info.get("modules", [])
    if modules:
        for mod_decl in modules:
            print(mod_decl)
        print()

    # Emit use statements (from JSON, extracted by Rust)
    uses = file_info.get("uses", [])
    if uses:
        for use_stmt in uses:
            print(use_stmt)
        print()

    # Emit types (always full source)
    for item in items:
        kind = item.get("kind", "")
        if kind in ("struct", "enum", "type_alias", "trait", "const", "static"):
            source = item.get("source", "")
            if source:
                print(source)
                print()

    # Emit functions
    for item in items:
        if item.get("kind") == "function":
            full_path = item.get("full_path", "")
            signature = item.get("signature", "")

            # Determine whether to show full body or just signature
            show_full_body = False

            # Root function in root file: always full body
            if is_root_file and full_path == root_full_path:
                show_full_body = True
            # Function in dependency chain: full body if depth >= 1
            elif full_path in dep_chain and depth >= 1:
                show_full_body = True

            # Emit full body or signature
            if show_full_body:
                if full_path == root_full_path:
                    # Root function: use its source
                    if root_source:
                        print(root_source)
                    else:
                        print(signature)
                else:
                    # Callee function: find source from callee_details
                    source = None
                    for callee in callee_details:
                        if callee.get("full_path") == full_path:
                            source = callee.get("source", "")
                            break
                    if source:
                        print(source)
                    else:
                        print(signature)
            else:
                # Just signature (header only) - add omitted marker
                print(f"{signature} {{ //OMITTED IMPLEMENTATION }}")

            print()

    # Emit success message to stderr
    func_label = function_name or root_full_path
    print(f"✓ Emitted {file_path} for {func_label}", file=sys.stderr)


if __name__ == "__main__":
    main()
